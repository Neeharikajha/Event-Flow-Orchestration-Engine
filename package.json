{
  "name": "event-stormer",
  "version": "2.0.0",
  "description": "Distributed event-driven orchestration system built on Node.js, Redis, and BullMQ",
  "main": "engine/api.js",
  "type": "module",
  "bin": {
    "processus-cli": "./bin/processus-cli"
  },
  "files": [
    "engine",
    "taskHandlers",
    "public",
    "server.js",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/processus-cli",
    "test": "node bin/processus-cli -f ./test/demo1.json -l info",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "automation",
    "redis",
    "bullmq",
    "event-driven",
    "pipelines"
  ],
  "author": "Neeharika Jha",
  "license": "MIT",
  "dependencies": {
    "async": "^3.2.5",
    "bullmq": "^5.65.0",
    "cli": "^1.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "ioredis": "^5.8.2",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.3.0",
    "redis": "^6.1.0",
    "underscore": "^1.13.6",
    "uuid": "^9.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
